# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=aeronav
POSTGRES_USER=aeronav
POSTGRES_PASSWORD=change_me_strong_password

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://aeronav:change_me_strong_password@db:5432/aeronav
JWT_SECRET=change_me_very_long_random_secret_at_least_32_chars
NODE_ENV=production

# ── GitHub Container Registry ─────────────────────────────────────────────────
# Automatically set by docker-compose when GITHUB_REPOSITORY is exported in the shell
# GITHUB_REPOSITORY=your-org/your-repo
